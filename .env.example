# ─── Flask Configuration ───
FLASK_SECRET_KEY=your_long_random_secret_key_here
FLASK_ENV=production

# ─── Database Configuration ───
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=campusbites
DB_PORT=3306

# ─── Razorpay Configuration ───
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Firebase Configuration ───
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Background Scheduler Times (24-Hour Format HH:MM, IST) ───
# Cleanup archives yesterday's orders. Auto-set populates today's menu.
CLEANUP_TIME=05:00
MENU_AUTOSET_TIME=05:05
